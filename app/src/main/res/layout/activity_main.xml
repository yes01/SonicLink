<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/sonic_link_bg"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="20dp"
        android:paddingEnd="16dp"
        android:paddingBottom="24dp">

        <TextView
            android:id="@+id/title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/main_title"
            android:textColor="@color/sonic_link_text"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/main_subtitle"
            android:textColor="@color/sonic_link_muted"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:background="@drawable/sonic_link_panel_bg"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/section_platform"
                android:textColor="@color/sonic_link_text"
                android:textSize="17sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/serverHost"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/sonic_link_input_bg"
                android:hint="@string/hint_server_host"
                android:inputType="textUri"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:singleLine="true"
                android:textColor="@color/sonic_link_text"
                android:textColorHint="@color/sonic_link_muted"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/httpUrl"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/sonic_link_input_bg"
                android:hint="@string/hint_http_url"
                android:inputType="textUri"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:singleLine="true"
                android:textColor="@color/sonic_link_text"
                android:textColorHint="@color/sonic_link_muted"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/webSocketUrl"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/sonic_link_input_bg"
                android:hint="@string/hint_websocket_url"
                android:inputType="textUri"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:singleLine="true"
                android:textColor="@color/sonic_link_text"
                android:textColorHint="@color/sonic_link_muted"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/token"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/sonic_link_input_bg"
                android:hint="@string/hint_token"
                android:inputType="textPassword"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:singleLine="true"
                android:textColor="@color/sonic_link_text"
                android:textColorHint="@color/sonic_link_muted"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/deviceName"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/sonic_link_input_bg"
                android:hint="@string/hint_device_name"
                android:inputType="text"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:singleLine="true"
                android:textColor="@color/sonic_link_text"
                android:textColorHint="@color/sonic_link_muted"
                android:textSize="14sp" />

            <CheckBox
                android:id="@+id/autoConnect"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:buttonTint="@color/sonic_link_primary"
                android:minHeight="48dp"
                android:text="@string/auto_connect_after_launch"
                android:textColor="@color/sonic_link_text"
                android:textSize="14sp" />

            <Button
                android:id="@+id/saveConfig"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="10dp"
                android:backgroundTint="@color/sonic_link_primary"
                android:text="@string/save_configuration"
                android:textAllCaps="false"
                android:textColor="@color/white" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/sonic_link_panel_bg"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/section_readiness"
                android:textColor="@color/sonic_link_text"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/configStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="@color/sonic_link_text"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/accessibilityStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/sonic_link_text"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/screenCaptureStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/sonic_link_text"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/agentStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/sonic_link_text"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/deviceStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/sonic_link_text"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/blockingStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/sonic_link_warning"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="vertical">

                <Button
                    android:id="@+id/openAccessibility"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:text="@string/open_accessibility"
                    android:textAllCaps="false" />

                <Button
                    android:id="@+id/requestCapture"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginTop="10dp"
                    android:text="@string/request_screen_capture"
                    android:textAllCaps="false" />
            </LinearLayout>

            <Button
                android:id="@+id/openAppSettings"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="10dp"
                android:text="@string/open_app_settings"
                android:textAllCaps="false" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical">

                <Button
                    android:id="@+id/startAgent"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:backgroundTint="@color/sonic_link_primary"
                    android:text="@string/start_agent"
                    android:textAllCaps="false"
                    android:textColor="@color/white" />

                <Button
                    android:id="@+id/stopAgent"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginTop="10dp"
                    android:text="@string/stop_agent"
                    android:textAllCaps="false" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/version"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:textColor="@color/sonic_link_muted"
            android:textSize="12sp" />
    </LinearLayout>
</ScrollView>
